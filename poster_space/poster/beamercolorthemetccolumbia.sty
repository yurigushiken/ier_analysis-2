% Gemini color theme — Teachers College, Columbia University
% Adapted from the Gemini default color theme

% ====================
% Definitions
% ====================

% Teachers College / Columbia University palette
\definecolor{tcnavy}{RGB}{0, 51, 102}       % Dark navy (primary)
\definecolor{tcblue}{RGB}{29, 79, 145}      % Medium blue
\definecolor{columbiablue}{RGB}{185, 217, 235}  % Columbia Blue (accent)
\definecolor{tclightblue}{RGB}{225, 238, 248}   % Very light blue (backgrounds)
\definecolor{tcgold}{RGB}{200, 170, 90}     % Gold accent

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=black,fg=white}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=tcnavy}

% Headline
\setbeamercolor{headline}{fg=white,bg=tcnavy}
\setbeamercolor{headline title}{fg=white}
\setbeamercolor{headline author}{fg=columbiablue}
\setbeamercolor{headline institute}{fg=columbiablue}
\setbeamercolor{headline rule}{bg=tcgold}

% Block
\setbeamercolor{block title}{fg=tcnavy,bg=white}
\setbeamercolor{block separator}{bg=tcnavy}
\setbeamercolor{block body}{fg=black,bg=white}

% Alert Block (for highlighted sections like Gordon 2003, GIVE vs SHOW)
\setbeamercolor{block title alerted}{fg=tcnavy,bg=tclightblue}
\setbeamercolor{block separator alerted}{bg=tcnavy}
\setbeamercolor{block body alerted}{fg=black,bg=tclightblue}

% Example Block (for take-away / conclusions)
\setbeamercolor{block title example}{fg=white,bg=tcblue}
\setbeamercolor{block separator example}{bg=tcblue}
\setbeamercolor{block body example}{fg=black,bg=tclightblue}

% Heading
\setbeamercolor{heading}{fg=tcnavy}

% Itemize
\setbeamercolor{item}{fg=tcnavy}

% Bibliography
\setbeamercolor{bibliography item}{fg=black}
\setbeamercolor{bibliography entry author}{fg=black}
\setbeamercolor{bibliography entry title}{fg=black}
\setbeamercolor{bibliography entry location}{fg=black}
\setbeamercolor{bibliography entry note}{fg=black}
